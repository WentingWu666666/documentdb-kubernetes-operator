+
+// reconcileOtelConfigMap ensures the OTel Collector base config ConfigMap exists and is up-to-date.
+func (r *DocumentDBReconciler) reconcileOtelConfigMap(ctx context.Context, documentdb *dbpreview.DocumentDB, namespace string) error {
+	logger := log.FromContext(ctx)
+	cmName := otelcfg.ConfigMapName(documentdb.Name)
+
+	cm := &corev1.ConfigMap{}
+	cm.Name = cmName
+	cm.Namespace = namespace
+
+	result, err := controllerutil.CreateOrUpdate(ctx, r.Client, cm, func() error {
+		if cm.Labels == nil {
+			cm.Labels = map[string]string{}
+		}
+		cm.Labels["app.kubernetes.io/managed-by"] = "documentdb-operator"
+		cm.Labels["app.kubernetes.io/component"] = "otel-collector"
+
+		baseYAML := otelcfg.GenerateBaseYAML(documentdb.Name, namespace, documentdb.Spec.Monitoring)
+		cm.Data = map[string]string{
+			"base.yaml": baseYAML,
+		}
+		return nil
+	})
+	if err != nil {
+		return fmt.Errorf("failed to reconcile OTel ConfigMap %s: %w", cmName, err)
+	}
+	if result != controllerutil.OperationResultNone {
+		logger.Info("OTel ConfigMap reconciled", "name", cmName, "operation", result)
+	}
+	return nil
+}
diff --git a/operator/src/internal/otel/config.go b/operator/src/internal/otel/config.go
new file mode 100644
index 0000000..ebaf17c
--- /dev/null
+++ b/operator/src/internal/otel/config.go
@@ -0,0 +1,81 @@
+// Copyright (c) Microsoft Corporation.
+// Licensed under the MIT License.
+
+package otel
+
+import (
+	"fmt"
+	"strings"
+
+	dbpreview "github.com/documentdb/documentdb-operator/api/preview"
+)
+
+// ConfigMapName returns the OTel ConfigMap name for a given DocumentDB cluster.
+func ConfigMapName(clusterName string) string {
+	return fmt.Sprintf("%s-otel-config", clusterName)
+}
+
+// GenerateBaseYAML generates the OTel Collector base.yaml content from a MonitoringSpec.
+// This config defines exporters, processors, and the service pipeline.
+// Receivers are defined in engine_metrics.yaml and host_metrics.yaml (shipped in the extension image).
+func GenerateBaseYAML(clusterName, namespace string, spec *dbpreview.MonitoringSpec) string {
+	var b strings.Builder
+
+	b.WriteString("# Auto-generated by documentdb-operator. Do not edit.\n")
+	b.WriteString("receivers:\n")
+	b.WriteString("  otlp:\n")
+	b.WriteString("    protocols:\n")
+	b.WriteString("      grpc:\n")
+	b.WriteString("        endpoint: \"0.0.0.0:4317\"\n")
+	b.WriteString("\n")
+
+	b.WriteString("processors:\n")
+	b.WriteString("  batch:\n")
+	b.WriteString("    send_batch_size: 1024\n")
+	b.WriteString("    timeout: 5s\n")
+	b.WriteString("\n")
+	b.WriteString("  resource:\n")
+	b.WriteString("    attributes:\n")
+	b.WriteString(fmt.Sprintf("      - key: documentdb.cluster\n        value: %q\n        action: upsert\n", clusterName))
+	b.WriteString(fmt.Sprintf("      - key: k8s.namespace.name\n        value: %q\n        action: upsert\n", namespace))
+	b.WriteString("      - key: k8s.pod.name\n        value: ${POD_NAME}\n        action: upsert\n")
+	b.WriteString("\n")
+
+	// Exporters
+	b.WriteString("exporters:\n")
+	b.WriteString("  debug:\n")
+	b.WriteString("    verbosity: basic\n")
+
+	exporterNames := []string{"debug"}
+
+	if spec.Exporter != nil && spec.Exporter.OTLP != nil && spec.Exporter.OTLP.Endpoint != "" {
+		insecure := spec.Exporter.OTLP.Insecure
+		b.WriteString("  otlp:\n")
+		b.WriteString(fmt.Sprintf("    endpoint: %q\n", spec.Exporter.OTLP.Endpoint))
+		b.WriteString("    tls:\n")
+		b.WriteString(fmt.Sprintf("      insecure: %t\n", insecure))
+		exporterNames = append(exporterNames, "otlp")
+	}
+
+	b.WriteString("\n")
+
+	// Service pipeline
+	b.WriteString("service:\n")
+	b.WriteString("  pipelines:\n")
+	b.WriteString("    metrics:\n")
+	b.WriteString("      receivers:\n")
+	b.WriteString("        - otlp\n")
+	b.WriteString("        - hostmetrics\n")
+	b.WriteString("        - sqlquery/connections\n")
+	b.WriteString("        - sqlquery/replication\n")
+	b.WriteString("        - sqlquery/index_stats\n")
+	b.WriteString("      processors:\n")
+	b.WriteString("        - resource\n")
+	b.WriteString("        - batch\n")
+	b.WriteString("      exporters:\n")
+	for _, name := range exporterNames {
+		b.WriteString(fmt.Sprintf("        - %s\n", name))
+	}
+
+	return b.String()
+}
